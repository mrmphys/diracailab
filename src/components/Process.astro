---
const steps = [
  {
    num: '01',
    title: 'Consult',
    desc: 'We meet to understand your goals, data, and constraints. No generic pitches - focused discovery only. We come with questions, not slide decks.',
  },
  {
    num: '02',
    title: 'Design',
    desc: 'Architecture, models, APIs, data pipelines, compliance, and infra plan - mapped before we write a single line of code.',
  },
  {
    num: '03',
    title: 'Build',
    desc: 'Rapid development with weekly check-ins. You see real working software at each milestone - not status updates.',
  },
  {
    num: '04',
    title: 'Deploy',
    desc: 'Production deployment with monitoring, alerting, and full handoff. We stay on until your team is confident and everything is green.',
  },
];
---
<section id="process">
  <div class="container">
    <span class="sec-tag f">Process</span>
    <h2 class="f d1">How we work.</h2>
    <ul class="proc-list" id="proc-list">
      {steps.map((step, i) => (
        <li class={`proc-item f d${i + 1}${i === 0 ? ' active' : ''}`}>
          <div class="proc-num">{step.num}</div>
          <div>
            <div class="proc-t">{step.title}</div>
            <div class="proc-d">{step.desc}</div>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<script>
  const steps = document.querySelectorAll('.proc-item');

  function setActive(i: number) {
    steps.forEach(s => s.classList.remove('active'));
    steps[i]?.classList.add('active');
  }

  // Desktop: mouse position
  document.getElementById('process')?.addEventListener('mousemove', (e: MouseEvent) => {
    let closest = 0, minDist = Infinity;
    steps.forEach((s, i) => {
      const r = s.getBoundingClientRect();
      const mid = r.top + r.height / 2;
      const dist = Math.abs(e.clientY - mid);
      if (dist < minDist) { minDist = dist; closest = i; }
    });
    setActive(closest);
  });

  // Mobile: scroll position
  function scrollActivate() {
    const mid = window.innerHeight / 2;
    let closest = 0, minDist = Infinity;
    steps.forEach((s, i) => {
      const r = s.getBoundingClientRect();
      const dist = Math.abs((r.top + r.height / 2) - mid);
      if (dist < minDist) { minDist = dist; closest = i; }
    });
    setActive(closest);
  }
  window.addEventListener('scroll', scrollActivate, { passive: true });
  window.addEventListener('touchmove', scrollActivate, { passive: true });
</script>
