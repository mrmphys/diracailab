---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
}

const {
  title = 'Dirac AI Lab - Custom AI Solutions | Voice Agents, LLM Integration & MLOps',
  description = 'Dirac AI Lab builds production-grade AI systems - voice AI agents, OpenClaw & LLM integration, recommendation engines, classification models, and MLOps pipelines. Get a free consultation.',
  canonicalUrl = Astro.url.href,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <meta name="author" content="Dirac AI Lab" />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="Dirac AI Lab" />
  <meta property="og:image" content="https://diracailab.com/og-image.png" />
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://diracailab.com/og-image.png" />
  <!-- Schema.org Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "Dirac AI Lab",
    "url": "https://diracailab.com",
    "email": "hina@diracailab.com",
    "description": "Dirac AI Lab builds production-grade AI systems - voice AI agents, LLM integration, recommendation engines, classification models, and MLOps pipelines.",
    "serviceType": ["Voice AI Agents", "LLM Integration", "Recommendation Systems", "MLOps", "Machine Learning", "AI Consulting"],
    "areaServed": "Worldwide"
  }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@300;400;500;700;900&display=swap" rel="stylesheet" />
</head>
<body>
  <slot />
</body>
</html>
